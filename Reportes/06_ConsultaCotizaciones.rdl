  <DataSets>
    <DataSet Name="dsCabCotizacion">
      <Query>
        <DataSourceName>cnnModProd</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@NumCotizacion">
            <Value>=Parameters!NumCotizacion.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@NombreProyecto">
            <Value>=Parameters!NombreProyecto.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Estado">
            <Value>=Parameters!Estado.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ValorMinimo">
            <Value>=Parameters!ValorMinimo.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ValorMaximo">
            <Value>=Parameters!ValorMaximo.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@AsignadoA2">
            <Value>=Parameters!AsignadoA2.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@FechaI">
            <Value>=Parameters!FechaI.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@NombreCliente">
            <Value>=Parameters!NombreCliente.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@Fechaf">
            <Value>=Parameters!FechaF.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@TipoCotizacion">
            <Value>=Parameters!TipoCotizacion.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>select * 
from vw_RPT_ConsultaCotizaciones Ct
where Ct.NumCotizacion like @NumCotizacion
and Ct.estado2 in (@Estado)
and Ct.NombreProyecto like @NombreProyecto 
and isnull(ct.PrecioFinal,0) between @ValorMinimo and @ValorMaximo
and Fecha between isnull(@FechaI,'19000101') and ISNULL(DATEADD (MINUTE,-1,(DATEADD (hh,24, @Fechaf))),GETDATE())
and AsignadoA2 like @AsignadoA2 
and NombreCliente like @NombreCliente
and tipo2 like @TipoCotizacion
and Tipo2 &lt;&gt;'OT'</CommandText>
      </Query>
      <Fields>
        <Field Name="Id">
          <DataField>Id</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Fecha">
          <DataField>Fecha</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
