    <DataSet Name="dsEstados">
      <Query>
        <DataSourceName>cnnModProd</DataSourceName>
        <CommandText>Select id, Nombre, Estado  
from Estados
where TipoDoc ='CT' order by id</CommandText>
      </Query>
      <Fields>
        <Field Name="id">
          <DataField>id</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="Nombre">
